<Window x:Class="cmdNet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cmdNet"
        mc:Ignorable="d"
        Height="550" Width="800" 
        FontSize="16" FontFamily="Arial Narrow"
        WindowStartupLocation="CenterScreen"
        Title="{Binding Source={x:Static local:LanguageManager.Instance}, Path=AppTitle}">

    <Grid>
        
        <TabControl>
            <!-- ========== تب اول: CMD ========== -->
            <TabItem Header="{Binding Source={x:Static local:LanguageManager.Instance}, Path=CmdTabHeader}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="4*" />
                    </Grid.ColumnDefinitions>

                    <!-- ستون چپ -->
                    <StackPanel Grid.Row="0">
                        <!-- دکمه‌های تغییر زبان -->
                       

                        <!-- دکمه Run -->
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnRun}"
                                Name="run" Click="run_ClickAsync" Style="{StaticResource ModernButtonStyle}" />

                        <!-- کامبوباکس دستورات -->
                        <ComboBox Name="comQuery" SelectedIndex="0" IsEditable="True"
                                  SelectionChanged="comQuery_SelectionChanged"
                                  PreviewKeyDown="comQuery_PreviewKeyDown"
                                  IsTextSearchEnabled="True" Height="30" Padding="1,2" />

                        <!-- توضیحات دستور -->
                        <TextBlock x:Name="DescriptionBlock"
                                   FlowDirection="RightToLeft"
                                   Margin="10"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="DarkSlateGray" />

                        <!-- دکمه نمایش رمز وای‌فای -->
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnShowWifi}"
                                Name="ShowWifi" Click="ShowWifi_Click" Style="{StaticResource ModernButtonStyle}" />

                        <!-- دکمه پاک‌کن -->
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnClear}"
                                Name="Clear" Click="Clear_Click" Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>

                    <!-- ستون راست -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Source={x:Static local:LanguageManager.Instance}, Path=LblInsertCommand}"
                                   Foreground="Black" Margin="10,5" />

                        <TextBox Name="insertQuery" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 Grid.Row="1" KeyDown="insertQuery_KeyDown" FontSize="16" Margin="10,5" />

                        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="10,5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="outputPanel" Margin="10" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========== تب دوم: جستجو ========== -->
            <TabItem Header="{Binding Source={x:Static local:LanguageManager.Instance}, Path=SearchTabHeader}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>

                    <!-- ستون چپ -->
                    <StackPanel Grid.Row="0">
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnSearch}"
                                Name="search" Click="search_Click" Style="{StaticResource ModernButtonStyle}" />

                        <TextBlock x:Name="DescriptionSerch" FlowDirection="RightToLeft"
                                   Margin="10" TextWrapping="Wrap" FontSize="11" Foreground="DarkSlateGray" />

                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnClearSearch}"
                                Name="ClearSearch" Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>

                    <!-- ستون راست -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="20,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Source={x:Static local:LanguageManager.Instance}, Path=SearchInsertWordLabel}"
                                       Grid.Row="0" />

                            <Grid Grid.Row="1">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Resources>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Margin" Value="0,0,20,0" />
                                        </Style>
                                    </StackPanel.Resources>
                                    <CheckBox x:Name="CheckDocx" Content=".docx" IsChecked="True" />
                                    <CheckBox x:Name="CheckPdf" Content=".pdf" IsChecked="True" />
                                    <CheckBox x:Name="CheckTxt" Content=".txt" IsChecked="True" />
                                    <CheckBox x:Name="CheckSubDir" Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=SearchSubDirLabel}"
                                              IsChecked="True" />
                                </StackPanel>
                            </Grid>

                            <TextBox Name="txtInsertKey" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                     Grid.Row="2" Height="25" FontSize="16" />

                            <Grid Grid.Row="3">
                                <ProgressBar x:Name="ProgressBar" Height="20" Margin="5" Minimum="0" Maximum="100" />
                                <TextBlock x:Name="ProgressText" Margin="5" />
                            </Grid>
                        </Grid>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
                            <StackPanel x:Name="outputPanelSearch" Margin="10" Focusable="True" IsHitTestVisible="True" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========== تب سوم: تولید رمز ========== -->
            <TabItem Header="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordTabHeader}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- طول رمز -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Label Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordLengthLabel}"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="LengthSlider" Minimum="4" Maximum="64" Value="16"
                                TickFrequency="1" IsSnapToTickEnabled="True" Width="400"
                                ValueChanged="LengthSlider_ValueChanged" />
                        <Label x:Name="LengthLabel" Content="12" Width="30" VerticalAlignment="Center"
                               Margin="10,0,0,0" FontWeight="Bold" />
                    </StackPanel>

                    <!-- نوع کاراکترها -->
                    <GroupBox Grid.Row="1" Header="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordCharTypesLabel}"
                              Margin="0,0,0,15">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="ChkLowerCase"
                                      Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordLowerCaseLabel}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkUpperCase"
                                      Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordUpperCaseLabel}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkDigits"
                                      Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordDigitsLabel}"
                                      IsChecked="True" Margin="0,2" />
                            <CheckBox x:Name="ChkSpecial"
                                      Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordSpecialLabel}"
                                      IsChecked="False" Margin="0,2" />
                        </StackPanel>
                    </GroupBox>

                    <!-- نمایش رمز -->
                    <Grid Grid.Row="2" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Label Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=PasswordGeneratedLabel}"
                               Grid.Row="0" Margin="0,0,0,5" />
                        <TextBox x:Name="TxtPassword" Grid.Row="1" IsReadOnly="True"
                                 TextWrapping="Wrap" FontSize="20" VerticalScrollBarVisibility="Auto" />
                    </Grid>

                    <!-- دکمه‌ها -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnGenerate"
                                Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnGenerate}"
                                Click="BtnGenerate_Click" Style="{StaticResource ModernButtonStyle}" />
                        <Button x:Name="BtnCopy"
                                Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnCopy}"
                                Click="BtnCopy_Click" Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== تب چهارم: سایر ========== -->
            <TabItem Header="{Binding Source={x:Static local:LanguageManager.Instance}, Path=OtherTabHeader}">
                <Grid Margin="10">
                    <StackPanel  HorizontalAlignment="Center" 
 VerticalAlignment="Center">
                        <Button x:Name="CreateUserActiveDriectory"
                                Click="CreateUserActiveDriectory_Click"
                                Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnUserActiveDirectory}"
                                Style="{StaticResource ModernButtonStyle}" />

                        <Button x:Name="PasswordRar"
                                Click="PasswordRar_Click"
                                Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnPasswordRar}"
                                Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Language">
               <Grid>
                    <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnPersian}"
                    Click="SetPersian_Click" 
                    
                    Style="{StaticResource ModernButtonStyle}" />
                        <Button Content="{Binding Source={x:Static local:LanguageManager.Instance}, Path=BtnEnglish}"
                    Click="SetEnglish_Click" 
                  
                    Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>
    </Grid>
    </TabItem>
            
            
            
            
        </TabControl>
    </Grid>
</Window>