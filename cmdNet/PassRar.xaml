<Window x:Class="cmdNet.PassRar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cmdNet"
        mc:Ignorable="d"
        Title="PassRar"  Width="800">
    <Grid>
       

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- انتخاب فایل RAR -->
                <GroupBox Header="1. انتخاب فایل RAR" Grid.Row="0" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtRarFile" Width="450" Margin="0,0,5,0" IsReadOnly="True"/>
                    <Button x:Name="btnSelectRar" Content="باز کردن" Click="BtnSelectRar_Click" Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </GroupBox>

                <!-- انتخاب فایل کلمات کلیدی -->
                <GroupBox Header="2. انتخاب فایل کلمات پایه" Grid.Row="1" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtWordsFile" Width="450" Margin="0,0,5,0" IsReadOnly="True"/>
                    <Button x:Name="btnSelectWords" Content="باز کردن" Click="BtnSelectWords_Click" Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </GroupBox>

                <!-- نمایش کلمات بارگذاری شده -->
                <GroupBox Header="3. کلمات بارگذاری شده" Grid.Row="2" Margin="0,5">
                    <ListBox x:Name="lstWords" Height="100" Margin="5"/>
                </GroupBox>

                <!-- تنظیمات ترکیبات -->
                <GroupBox Header="4. تنظیمات تولید ترکیبات" Grid.Row="3" Margin="0,5">
                    <StackPanel Margin="5">
                        <CheckBox x:Name="chkSingleWords" Content="کلمات تکی" IsChecked="True" Margin="0,2"/>
                        <CheckBox x:Name="chkDoubleCombinations" Content="ترکیبات دوتایی (کلمه اول + کلمه دوم)" IsChecked="True" Margin="0,2"/>
                        <CheckBox x:Name="chkDoubleCombinationsReverse" Content="ترکیبات دوتایی معکوس (کلمه دوم + کلمه اول)" IsChecked="True" Margin="0,2"/>
                        <CheckBox x:Name="chkIncludeSelfCombination" Content="تکرار کلمه با خودش (word+word)" IsChecked="False" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <!-- دکمه شروع و وضعیت -->
                <Grid Grid.Row="4" Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="progressBar" Height="25" Grid.Column="0" Margin="0,0,10,0"/>
                <Button x:Name="btnStart" Content="شروع تست" Click="BtnStart_Click" Width="100" Grid.Column="1" Margin="0,0,5,0" Style="{StaticResource ModernButtonStyle}"/>
                <Button x:Name="btnStop" Content="توقف" Click="BtnStop_Click" Style="{StaticResource ModernButtonStyle}" Grid.Column="2" IsEnabled="False"/>
                </Grid>

                <!-- خروجی تست -->
                <GroupBox Header="5. نتیجه تست" Grid.Row="5" Margin="0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="lblStatus" Grid.Row="0" Margin="5" FontWeight="Bold"/>
                        <ListBox x:Name="lstResults" Grid.Row="1" Margin="5" FontFamily="Consolas"/>
                    </Grid>
                </GroupBox>

                <!-- دکمه ذخیره نتیجه -->
            <Button x:Name="btnSaveResult" Content="ذخیره نتیجه" Click="BtnSaveResult_Click" Grid.Row="6" Width="120" HorizontalAlignment="Right" Margin="0,10" Style="{StaticResource ModernButtonStyle}"/>
            </Grid>
      






    </Grid>
</Window>
