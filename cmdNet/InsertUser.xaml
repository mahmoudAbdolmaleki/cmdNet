<Window x:Class="cmdNet.InsertUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cmdNet"
        mc:Ignorable="d"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="InsertUser"  Width="800" >
    <!--<Viewbox Stretch="Fill">-->
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Connection Settings"
                  Grid.Row="0"
                  Margin="0,0,0,10">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Domain Controller:"
                           VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1" 
                         Text="{Binding DomainController}" />

                    <TextBlock Grid.Row="1"
                           Text="Admin Username:"
                           VerticalAlignment="Center"/>

                    <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding AdminUsername}" />

                    <TextBlock Grid.Row="2"
                           Text="Admin Password:"
                           VerticalAlignment="Center"/>

                    <PasswordBox x:Name="txtPassword"
                             Grid.Row="2"
                             Grid.Column="1" />

                    <!--<TextBlock Grid.Row="3"
                           Text="OU Path:"
                           VerticalAlignment="Center"/>-->

                    <!--<TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding OuPath}" />-->

                </Grid>

            </GroupBox>

            <GroupBox Header="Excel File"
                  Grid.Row="1"
                  Margin="0,0,0,10">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding ExcelFilePath}" />

                    <Button Grid.Column="1"
                        Content="Browse"
                       Style="{StaticResource ModernButtonStyle}"
                        Click="Browse_Click"/>

                </Grid>

            </GroupBox>

            <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">


                <Button Content="Analyze"
                    Name="Analyze"
                  
       Style="{StaticResource ModernButtonStyle}"
        Click="Analyze_Click"/>

                <Button Content="CreteUser"
                    Name="CreateUser"
                    
       Style="{StaticResource ModernButtonStyle}"
        Click="Execute_Click"/>
                <Button Content="Excel Report"
                    Name="ExcelReport"
                    
       Style="{StaticResource ModernButtonStyle}"
        Click="ExportReport_Click"/>


            </StackPanel>

            <ProgressBar Grid.Row="3"
                     Height="25"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding ProgressPercent}"
                     Margin="0,0,0,10"/>


            <Grid Grid.Row="4">

                <Border BorderBrush="Gray"
            BorderThickness="1"
            Margin="10">

                    <Grid >

                        <!-- 🔥 HEADER (ثابت) -->
                        <Grid Background="#EEE" >

                            <Grid.ColumnDefinitions>
                                <!--<ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="140"/>-->

                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Text="First Name" FontWeight="Bold" Grid.Column="0"/>
                            <TextBlock Text="Last Name" FontWeight="Bold" Grid.Column="1"/>
                            <TextBlock Text="UserName" FontWeight="Bold" Grid.Column="2"/>
                            <TextBlock Text="Similar User" FontWeight="Bold" Grid.Column="3"/>
                            <TextBlock Text="Similar Name" FontWeight="Bold" Grid.Column="4"/>
                            <TextBlock Text="Action" FontWeight="Bold" Grid.Column="5"/>

                        </Grid>

                        <!-- 🔥 BODY (Scrollable) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Margin="0,30,0,0">
                            <ItemsControl ItemsSource="{Binding Results}"
              AlternationCount="2">

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border BorderBrush="#DDD"
                    BorderThickness="1"
                    Margin="2"
                    Padding="6">

                                            <Border.Style>
                                                <Style TargetType="Border">

                                                    <!-- رنگ پیش‌فرض -->
                                                    <Setter Property="Background" Value="White"/>

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                           Path=(ItemsControl.AlternationIndex)}"
                                         Value="1">

                                                            <Setter Property="Background" Value="#F5F5F5"/>

                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>
                                            </Border.Style>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <!--<ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="140"/>-->
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding FirstName}" Grid.Column="0"/>
                                                <TextBlock Text="{Binding LastName}" Grid.Column="1"/>
                                                <TextBlock Text="{Binding UserName}" Grid.Column="2"/>
                                                <TextBlock Text="{Binding SimilarUserName}" Grid.Column="3"/>
                                                <TextBlock Text="{Binding SimilarDisplayName}" Grid.Column="4"/>

                                                <ComboBox Grid.Column="5"
                              ItemsSource="{Binding DataContext.Actions, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                              SelectedItem="{Binding Action, Mode=TwoWay}"
                              Height="25"/>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>



            <TextBlock Grid.Row="5"
                   Margin="0,10,0,0"
                   FontWeight="Bold"
                   Text="{Binding Summary}" />

        </Grid>
    <!--</Viewbox>-->
</Window>
